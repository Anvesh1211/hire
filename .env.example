# ProofSAR AI Environment Configuration
# Copy this file to .env and update with your values

# Security Settings
JWT_SECRET_KEY=your-very-secure-secret-key-change-this-in-production-2024
JWT_ALGORITHM=HS256
SESSION_TIMEOUT=3600

# Database Configuration (SQLite fallback for development)
DATABASE_URL=sqlite:///./proofsar.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proofsar_ai
DB_USER=postgres
DB_PASSWORD=dev_password

# Email Service Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@barclays.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_USE_TLS=true
EMAIL_TIMEOUT=30

# AI Model Configuration
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI=false
LOCAL_MODEL_PATH=./models
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/proofsar_ai.log
MAX_FILE_SIZE=10485760
SHOW_DEVELOPER_MODE=true

# Risk Thresholds
RISK_THRESHOLD_CRITICAL=0.75
RISK_THRESHOLD_HIGH=0.5
RISK_THRESHOLD_MEDIUM=0.25
RISK_THRESHOLD_LOW=0.0

# Alert Recipients
ALERT_RECIPIENTS_HIGH_RISK=compliance@barclays.com,supervisor@barclays.com
ALERT_RECIPIENTS_PENDING_REVIEW=analyst@barclays.com
ALERT_RECIPIENTS_APPROVED=compliance@barclays.com
ALERT_RECIPIENTS_REJECTED=analyst@barclays.com,supervisor@barclays.com

# UI Configuration
UI_THEME=light
UI_LAYOUT=wide

# Cache Configuration
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0
